# F2-JARVIS — Submodules des SaaS F2
#
# Chaque SaaS a son propre compte/org GitHub pour profiter du free tier
# par org (Actions, Packages, etc.).
#
# À remplir avec les URLs réelles quand les comptes sont créés.
#
# Utilisation :
#   git submodule add <url> saas/<name>
#   git submodule update --init --recursive
#   git submodule update --remote  # sync dernière version

# [submodule "saas/leak-detector"]
#   path = saas/leak-detector
#   url = git@github.com:foundrytwo-ld/leak-detector.git
#   branch = main

