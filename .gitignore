# F2-JARVIS — .gitignore

# Secrets
.claude/settings.local.json
.env
.env.local
.env.*.local
*.key
*.pem
*secrets*
*credentials*

# Ouroboros state (runtime, pas versionné)
brain/ouroboros/state/
brain/ouroboros/state/*

# Kill-switches (runtime flags)
ops/kill-switches/*.flag

# MemPalace runtime
brain/mempalace/chroma/
brain/mempalace/knowledge_graph.db
brain/mempalace/knowledge_graph.db-journal
brain/mempalace/entities.json
brain/mempalace/mempalace.yaml

# Mem0 runtime
brain/mem0/*.jsonl

# Graphify output (régénéré) — on garde GRAPH_REPORT.md et wiki/, on ignore tout le reste
graphify-out/*
!graphify-out/GRAPH_REPORT.md
!graphify-out/wiki/

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.ENV/
.venv.*
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# OS
.DS_Store
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Temporary
*.tmp
*.bak
tmp/
temp/

# Raw folder inbox — les fichiers bruts non versionnés par défaut
# (décommenter si tu ne veux pas versionner les raw inputs)
# raw/inbox/
# raw/screenshots/
# raw/transcripts/

# UI builds
ui/web/.next/
ui/web/out/
ui/brain-3d/dist/
